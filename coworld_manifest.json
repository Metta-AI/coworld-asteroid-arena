{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/metta/main/packages/coworld/src/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "asteroid_arena",
    "version": "0.1.0",
    "description": "A BitWorld arcade game where players pilot ships, shoot asteroids, and fight each other.",
    "owner": "treeform@softmax.com",
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens"
      ],
      "properties": {
        "tokens": {
          "description": "One connection token per player slot.",
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string"
          },
          "default": []
        },
        "seed": {
          "description": "Random seed.",
          "type": "integer",
          "minimum": 0,
          "default": 677410
        },
        "duration": {
          "description": "Game duration in seconds. Use 0 for no time limit.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "names",
        "scores"
      ],
      "properties": {
        "names": {
          "description": "One player name per slot.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scores": {
          "description": "One score per player slot.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "protocols": {
      "player": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      },
      "global": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      }
    },
    "docs": {
      "readme": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/coworld-asteroid-arena/blob/master/README.md"
      },
      "pages": [
        {
          "id": "rules.md",
          "title": "Rules",
          "content": {
            "type": "text",
            "value": "# Asteroid Arena Rules\n\nPlayers pilot ships in a wrapping arena. Shoot asteroids and rival ships to score points. Red cooperative asteroids require hits from two different players. Planets can be captured and held for bonus score."
          }
        },
        {
          "id": "play_asteroid_arena.md",
          "title": "How to Play",
          "content": {
            "type": "text",
            "value": "# How to Play Asteroid Arena\n\nConnect to the player websocket, read sprite protocol updates, and send input masks. Use thrust and rotation to steer, fire at asteroids, and cooperate with other players to break red asteroids or capture planets."
          }
        },
        {
          "id": "reward.md",
          "title": "Reward Protocol",
          "content": {
            "type": "uri",
            "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/reward_v1.md"
          }
        }
      ]
    },
    "runnable": {
      "type": "game",
      "image": "public.ecr.aws/s3j4p9s7/treeform/games/asteroid-arena@sha256:26526c39c3551f83deb9a5046b787ca999361d3cd9f37e29e6dc501dba5372fb",
      "run": ["/bin/asteroid_arena"]
    }
  },
  "player": [
    {
      "id": "shooter",
      "name": "Shooter",
      "description": "Simple asteroid-hunting bot that steers toward the nearest asteroid and fires.",
      "type": "player",
      "image": "public.ecr.aws/s3j4p9s7/treeform/players/shooter@sha256:a6cf59ca3fa35f74783b6349ae5b65f6c79b29700f78ba143b4f52a2e2f61f4a",
      "run": ["/bin/shooter"]
    }
  ],
  "reporter": [
    {
      "id": "default-reporter",
      "name": "Default Reporter",
      "description": "Default Coworld reporter for generic episode artifacts.",
      "type": "reporter",
      "image": "public.ecr.aws/q5f4m8t9/cogames@sha256:396e56a9ba1576aecc5b9868a85fa309ea98fdbbf8d656c94ec021906197ea52"
    }
  ],
  "grader": [
    {
      "id": "bitworld-score-grader",
      "name": "BitWorld Score Grader",
      "type": "grader",
      "description": "Generic BitWorld grader that scores episode interest from score spread and game-specific activity signals.",
      "source_url": "https://github.com/Metta-AI/graders/tree/main/graders/bitworld_score/bitworld_score_grader",
      "image": "ghcr.io/metta-ai/graders-bitworld-score:latest"
    }
  ],
  "variants": [
    {
      "id": "smoke",
      "name": "Smoke",
      "game_config": {
        "seed": 677410,
        "duration": 0
      },
      "description": "Short deterministic Asteroid Arena configuration used for manifest checks."
    }
  ],
  "certification": {
    "game_config": {
      "seed": 677410,
      "duration": 0
    },
    "players": [
      {
        "player_id": "shooter"
      },
      {
        "player_id": "shooter"
      }
    ]
  }
}
