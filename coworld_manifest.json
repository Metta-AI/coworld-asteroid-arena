{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/metta/main/packages/cogames/src/cogames/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "asteroid_arena",
    "version": "0.1.0",
    "description": "A BitWorld arcade game where players pilot ships, shoot asteroids, and fight each other.",
    "owner": "treeform@softmax.com",
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tokens": {
          "description": "One connection token per player slot.",
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": "string"
          },
          "default": []
        },
        "seed": {
          "description": "Random seed.",
          "type": "integer",
          "minimum": 0,
          "default": 677410
        },
        "duration": {
          "description": "Game duration in seconds. Use 0 for no time limit.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "names",
        "scores"
      ],
      "properties": {
        "names": {
          "description": "One player name per slot.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scores": {
          "description": "One score per player slot.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "protocols": {
      "player": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md",
      "global": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md",
      "reward": "https://github.com/Metta-AI/bitworld/blob/master/docs/reward_v1.md"
    },
    "runnable": {
      "type": "game",
      "image": "public.ecr.aws/s3j4p9s7/treeform/games/asteroid-arena:latest",
      "run": ["/bin/asteroid_arena", "--address:0.0.0.0", "--port:8080"]
    }
  },
  "player": [
    {
      "id": "shooter",
      "name": "Shooter",
      "description": "Simple asteroid-hunting bot that steers toward the nearest asteroid and fires.",
      "runnable": {
        "type": "player",
        "image": "public.ecr.aws/s3j4p9s7/treeform/players/shooter:latest",
        "run": ["/bin/shooter"]
      }
    }
  ],
  "variants": [
    {
      "id": "smoke",
      "name": "Smoke",
      "game_config": {
        "seed": 677410,
        "duration": 30
      },
      "description": "Short deterministic Asteroid Arena configuration used for manifest checks."
    }
  ],
  "certification": {
    "variant_id": "smoke",
    "players": [
      {
        "player_id": "shooter",
        "initial_params": {
          "name": "slot_0"
        }
      },
      {
        "player_id": "shooter",
        "initial_params": {
          "name": "slot_1"
        }
      }
    ]
  }
}
